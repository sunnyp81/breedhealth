---
import BaseHead from '../components/BaseHead.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
}

const { title, description, canonicalUrl, ogImage } = Astro.props;

const navLinks = [
  { label: 'Breeds', href: '/breeds/' },
  { label: 'Health Conditions', href: '/conditions/' },
  { label: 'Diet & Nutrition', href: '/diet/' },
  { label: 'Compare Breeds', href: '/compare/' },
  { label: 'Guides', href: '/guides/' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      canonicalUrl={canonicalUrl}
      ogImage={ogImage}
    />
    <slot name="head" />
  
    <!-- Google Analytics 4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-DHJZXPN88D"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-DHJZXPN88D');
    </script>
  </head>

  <body class="bg-bg text-text min-h-screen flex flex-col">

    <!-- Header -->
    <header class="bg-white border-b border-border sticky top-0 z-50 shadow-sm">
      <div class="max-w-6xl mx-auto px-4">
        <div class="flex items-center justify-between h-16">

          <!-- Logo -->
          <a
            href="/"
            class="flex items-center gap-2 no-underline text-primary font-bold text-xl hover:text-primary-dark transition-colors"
            aria-label="BreedHealth home"
          >
            <svg width="28" height="28" viewBox="0 0 32 32" fill="none" aria-hidden="true">
              <ellipse cx="9" cy="7" rx="4" ry="5" fill="currentColor" opacity="0.85"/>
              <ellipse cx="23" cy="7" rx="4" ry="5" fill="currentColor" opacity="0.85"/>
              <ellipse cx="4" cy="16" rx="3" ry="4" fill="currentColor" opacity="0.85"/>
              <ellipse cx="28" cy="16" rx="3" ry="4" fill="currentColor" opacity="0.85"/>
              <path d="M16 12c-5 0-9 3.5-9 8 0 3.5 4 7 9 7s9-3.5 9-7c0-4.5-4-8-9-8z" fill="currentColor"/>
            </svg>
            BreedHealth
          </a>

          <!-- Desktop nav -->
          <nav class="hidden sm:flex items-center gap-1" aria-label="Main navigation">
            {navLinks.map((link) => (
              <a
                href={link.href}
                class="px-3 py-2 rounded-lg text-sm font-medium text-text-muted hover:text-primary hover:bg-bg-alt transition-colors no-underline"
              >
                {link.label}
              </a>
            ))}
          </nav>

          <!-- Mobile hamburger -->
          <button
            id="mobile-menu-btn"
            class="sm:hidden flex flex-col justify-center items-center gap-1.5 w-10 h-10 rounded-lg hover:bg-bg-alt transition-colors cursor-pointer"
            aria-label="Toggle navigation menu"
            aria-expanded="false"
            aria-controls="mobile-menu"
          >
            <span class="hamburger-line block w-5 h-0.5 bg-text rounded transition-all duration-200"></span>
            <span class="hamburger-line block w-5 h-0.5 bg-text rounded transition-all duration-200"></span>
            <span class="hamburger-line block w-5 h-0.5 bg-text rounded transition-all duration-200"></span>
          </button>
        </div>

        <!-- Mobile nav menu -->
        <nav
          id="mobile-menu"
          class="hidden sm:hidden pb-4"
          aria-label="Mobile navigation"
        >
          {navLinks.map((link) => (
            <a
              href={link.href}
              class="block px-3 py-2.5 rounded-lg text-sm font-medium text-text-muted hover:text-primary hover:bg-bg-alt transition-colors no-underline"
            >
              {link.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <!-- Main content -->
    <main class="flex-1">
      <div class="max-w-6xl mx-auto px-4 py-8">
        <slot />
      </div>
    </main>

    <!-- Footer -->
    <footer class="bg-primary text-white mt-16">
      <div class="max-w-6xl mx-auto px-4 py-12">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 mb-10">

          <!-- Brand -->
          <div class="lg:col-span-1">
            <a href="/" class="flex items-center gap-2 no-underline text-white font-bold text-lg mb-3 hover:text-accent transition-colors">
              <svg width="22" height="22" viewBox="0 0 32 32" fill="none" aria-hidden="true">
                <ellipse cx="9" cy="7" rx="4" ry="5" fill="currentColor" opacity="0.9"/>
                <ellipse cx="23" cy="7" rx="4" ry="5" fill="currentColor" opacity="0.9"/>
                <ellipse cx="4" cy="16" rx="3" ry="4" fill="currentColor" opacity="0.9"/>
                <ellipse cx="28" cy="16" rx="3" ry="4" fill="currentColor" opacity="0.9"/>
                <path d="M16 12c-5 0-9 3.5-9 8 0 3.5 4 7 9 7s9-3.5 9-7c0-4.5-4-8-9-8z" fill="currentColor"/>
              </svg>
              BreedHealth
            </a>
            <p class="text-sm text-white/70 leading-relaxed">
              Expert dog breed health guides, condition profiles, and nutrition advice to help you give your dog the best life.
            </p>
          </div>

          <!-- Explore -->
          <div>
            <h3 class="font-semibold text-accent mb-3 text-sm uppercase tracking-wide">Explore</h3>
            <ul class="space-y-2 text-sm">
              <li><a href="/breeds/" class="text-white/80 hover:text-white no-underline hover:underline transition-colors">All Breeds</a></li>
              <li><a href="/conditions/" class="text-white/80 hover:text-white no-underline hover:underline transition-colors">Health Conditions</a></li>
              <li><a href="/diet/" class="text-white/80 hover:text-white no-underline hover:underline transition-colors">Diet & Nutrition</a></li>
              <li><a href="/compare/" class="text-white/80 hover:text-white no-underline hover:underline transition-colors">Compare Breeds</a></li>
              <li><a href="/guides/" class="text-white/80 hover:text-white no-underline hover:underline transition-colors">Health Guides</a></li>
            </ul>
          </div>

          <!-- Popular Breeds -->
          <div>
            <h3 class="font-semibold text-accent mb-3 text-sm uppercase tracking-wide">Popular Breeds</h3>
            <ul class="space-y-2 text-sm">
              <li><a href="/breeds/labrador-retriever/" class="text-white/80 hover:text-white no-underline hover:underline transition-colors">Labrador Retriever</a></li>
              <li><a href="/breeds/golden-retriever/" class="text-white/80 hover:text-white no-underline hover:underline transition-colors">Golden Retriever</a></li>
              <li><a href="/breeds/german-shepherd/" class="text-white/80 hover:text-white no-underline hover:underline transition-colors">German Shepherd</a></li>
              <li><a href="/breeds/french-bulldog/" class="text-white/80 hover:text-white no-underline hover:underline transition-colors">French Bulldog</a></li>
              <li><a href="/breeds/border-collie/" class="text-white/80 hover:text-white no-underline hover:underline transition-colors">Border Collie</a></li>
            </ul>
          </div>

          <!-- Email capture -->
          <div>
            <h3 class="font-semibold text-accent mb-3 text-sm uppercase tracking-wide">Stay Updated</h3>
            <p class="text-sm text-white/70 mb-3">Breed health tips, vet insights and guides — free.</p>
            <form id="footer-email-form" class="space-y-2" novalidate>
              <input type="hidden" name="accessKey" value="YOUR_ACCESS_KEY" />
              <input type="hidden" name="redirectTo" value="" id="footer-redirect-field" />
              <input
                type="email"
                name="email"
                required
                placeholder="your@email.com"
                class="w-full px-3 py-2.5 rounded-lg text-sm text-text bg-white border border-white/20 placeholder-text-light focus:outline-none focus:ring-2 focus:ring-accent"
                autocomplete="email"
              />
              <button
                type="submit"
                class="w-full px-4 py-2.5 bg-accent hover:bg-accent-dark text-white font-semibold rounded-lg text-sm transition-colors cursor-pointer"
              >
                Subscribe
              </button>
            </form>
            <p id="footer-email-success" class="hidden mt-2 text-sm text-accent font-medium" role="status" aria-live="polite">
              Subscribed! Talk soon.
            </p>
          </div>
        </div>

        <div class="border-t border-white/20 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-white/50">
          <p>&copy; {new Date().getFullYear()} BreedHealth. All rights reserved.</p>
          <nav class="flex gap-4" aria-label="Legal navigation">
            <a href="/privacy/" class="hover:text-white no-underline hover:underline transition-colors">Privacy Policy</a>
            <a href="/disclaimer/" class="hover:text-white no-underline hover:underline transition-colors">Disclaimer</a>
            <a href="/about/" class="hover:text-white no-underline hover:underline transition-colors">About</a>
            <a href="/contact/" class="hover:text-white no-underline hover:underline transition-colors">Contact</a>
          </nav>
        </div>
      </div>
    </footer>

  </body>
</html>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const lines = btn?.querySelectorAll('.hamburger-line') as NodeListOf<HTMLElement> | undefined;

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('hidden') === false;

    if (isOpen) {
      menu?.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
      lines?.forEach((line, i) => {
        line.style.transform = '';
        line.style.opacity = '';
      });
    } else {
      menu?.classList.remove('hidden');
      btn.setAttribute('aria-expanded', 'true');
      if (lines && lines.length >= 3) {
        lines[0].style.transform = 'translateY(8px) rotate(45deg)';
        lines[1].style.opacity = '0';
        lines[2].style.transform = 'translateY(-8px) rotate(-45deg)';
      }
    }
  });

  // Footer email form
  const footerForm = document.getElementById('footer-email-form') as HTMLFormElement | null;
  const footerSuccess = document.getElementById('footer-email-success');
  const footerRedirect = document.getElementById('footer-redirect-field') as HTMLInputElement | null;

  if (footerRedirect) {
    footerRedirect.value = window.location.href;
  }

  footerForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!footerForm) return;

    const submitBtn = footerForm.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Subscribing...';
    }

    try {
      const data = new FormData(footerForm);
      const response = await fetch('https://api.staticforms.xyz/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(Object.fromEntries(data.entries())),
      });

      if (response.ok) {
        footerForm.classList.add('hidden');
        footerSuccess?.classList.remove('hidden');
      } else {
        throw new Error('Failed');
      }
    } catch {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Subscribe';
      }
    }
  });
</script>
