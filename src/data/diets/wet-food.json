{
  "name": "Wet Food (Canned)",
  "slug": "wet-food",
  "description": "Wet or canned food contains 70-80% moisture and is often more palatable than dry kibble. It can be fed as a complete diet or used as a topper. Suitable for dogs of all life stages depending on the specific formula.",
  "suitable_for": [
    "dogs with dental problems",
    "picky eaters",
    "dogs with kidney disease needing increased hydration",
    "senior dogs with reduced appetite"
  ],
  "benefits": [
    "High moisture content supports hydration and urinary health",
    "Highly palatable for fussy dogs",
    "Lower carbohydrate content than many kibbles",
    "Easier to eat for dogs with dental issues"
  ],
  "risks": [
    "More expensive per calorie than dry food",
    "Can contribute to dental plaque if used exclusively",
    "Shorter shelf life once opened",
    "Some formulas are nutritionally incomplete"
  ],
  "recommended_brands": [
    "Royal Canin (canned)",
    "Hill's Science Diet (canned)",
    "Purina Pro Plan Savor",
    "Merrick Classic"
  ],
  "feeding_guidelines": {
    "small": {
      "cups_per_day": "1-2 cans (3.5oz)",
      "frequency": "2 meals"
    },
    "medium": {
      "cups_per_day": "1-2 cans (13oz)",
      "frequency": "2 meals"
    },
    "large": {
      "cups_per_day": "2-3 cans (13oz)",
      "frequency": "2 meals"
    },
    "giant": {
