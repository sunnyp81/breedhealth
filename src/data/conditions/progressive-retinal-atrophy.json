{
  "name": "Progressive Retinal Atrophy (PRA)",
  "slug": "progressive-retinal-atrophy",
  "category": "Eye",
  "description": "PRA is a group of hereditary diseases causing progressive degeneration of the photoreceptor cells in the retina. It leads to night blindness first, followed by complete blindness. There is no treatment, but DNA tests exist for many forms.",
  "symptoms": [
    "Night blindness (early sign)",
    "Reluctance to enter dark rooms",
    "Dilated pupils",
    "Reduced daytime vision",
    "Reflective eye shine (tapetal hyperreflectivity)"
  ],
  "severity": "high",
  "treatment_overview": "There is no effective treatment or cure for PRA. Management focuses on adapting the dog's environment to maintain quality of life as vision deteriorates.",
  "prevention_tips": [
    "DNA test breeding stock before mating",
    "Only breed clear or carrier-to-clear pairings",
    "Annual ophthalmology screening (BVA/KC scheme)"
  ],
  "affected_breeds": [
    "labrador-retriever",
    "cocker-spaniel",
    "miniature-poodle",
    "irish-setter",
    "border-collie",
    "tibetan-terrier"
  ],
  "typical_onset": "3-8 years",
  "hereditary": true,
  "estimated_treatment_cost": "£0 (management only)",
