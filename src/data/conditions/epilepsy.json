{
  "name": "Epilepsy",
  "slug": "epilepsy",
  "category": "Neurological",
  "description": "Epilepsy is the most common neurological disorder in dogs, characterised by recurrent seizures. Idiopathic (genetic) epilepsy is the most frequent form in young to middle-aged dogs with no underlying structural brain lesion.",
  "symptoms": [
    "Generalised seizures (paddling, loss of consciousness)",
    "Focal seizures (facial twitching, fly-biting)",
    "Post-ictal confusion",
    "Sudden falling",
    "Cluster seizures"
  ],
  "severity": "medium",
  "treatment_overview": "Anticonvulsant drugs (phenobarbital, potassium bromide, levetiracetam) control seizures in the majority of cases. Treatment is lifelong. Cluster seizures and status epilepticus require emergency treatment.",
  "prevention_tips": [
    "DNA testing available for several breeds",
    "Avoid breeding affected dogs with idiopathic epilepsy"
  ],
  "affected_breeds": [
    "border-collie",
    "labrador-retriever",
    "golden-retriever",
    "beagle",
    "german-shepherd",
    "belgian-shepherd"
  ],
  "typical_onset": "1-5 years",
  "hereditary": true,
  "estimated_treatment_cost": "£500-£2,000/year",
