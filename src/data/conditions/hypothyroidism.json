{
  "name": "Hypothyroidism",
  "slug": "hypothyroidism",
  "category": "Endocrine",
  "description": "Hypothyroidism is the most common endocrine disorder in dogs, caused by reduced thyroid hormone production — most often from immune-mediated thyroiditis or idiopathic follicular atrophy. It affects metabolism, skin, and coat quality.",
  "symptoms": [
    "Weight gain without diet change",
    "Lethargy",
    "Cold intolerance",
    "Bilateral symmetrical hair loss",
    "Thickened skin",
    "Ear infections"
  ],
  "severity": "low",
  "treatment_overview": "Daily oral thyroxine (levothyroxine) supplementation is highly effective and required for life. Dosing is adjusted based on thyroid level monitoring every 6-12 months.",
  "prevention_tips": [
    "No proven prevention",
    "Regular blood screening in at-risk breeds from age 4"
  ],
  "affected_breeds": [
    "golden-retriever",
    "dobermann",
