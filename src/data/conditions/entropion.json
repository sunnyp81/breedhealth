{
  "name": "Entropion",
  "slug": "entropion",
  "category": "Eye",
  "description": "Entropion is an inward rolling of the eyelid margin, causing the eyelashes and skin to rub against the corneal surface. This produces chronic irritation, pain, corneal ulceration, and scarring that can impair vision.",
  "symptoms": [
    "Squinting or pawing at eye",
    "Excessive tearing",
    "Eye discharge",
    "Corneal cloudiness",
    "Redness around eye"
  ],
  "severity": "medium",
  "treatment_overview": "Temporary eyelid tacking can relieve discomfort in puppies pending maturity. Definitive surgical correction (Hotz-Celsus procedure) is highly effective in adults.",
  "prevention_tips": [
    "Avoid breeding dogs with severe conformational entropion",
    "Do not breed surgically corrected dogs"
  ],
