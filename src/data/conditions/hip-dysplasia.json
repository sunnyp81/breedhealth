{
  "name": "Hip Dysplasia",
  "slug": "hip-dysplasia",
  "category": "Orthopedic",
  "description": "Hip dysplasia is a genetic condition where the hip joint doesn't develop properly, causing the ball and socket to not fit together correctly. This leads to joint deterioration, pain, and arthritis over time.",
  "symptoms": [
    "Difficulty rising",
    "Reluctance to jump",
    "Bunny-hopping gait",
    "Loss of thigh muscle",
    "Stiffness after rest"
  ],
  "severity": "high",
  "treatment_overview": "Treatment ranges from weight management and physical therapy for mild cases to total hip replacement for severe cases. NSAIDs and joint supplements help manage pain.",
  "prevention_tips": [
    "Screen breeding stock with hip scoring",
    "Maintain healthy weight",
    "Avoid excessive puppy exercise",
    "Feed large-breed puppy food"
  ],
  "affected_breeds": [
    "labrador-retriever",
    "german-shepherd",
    "golden-retriever",
    "rottweiler",
    "great-dane"
  ],
  "typical_onset": "1-2 years",
  "hereditary": true,
  "estimated_treatment_cost": "£1,500-£6,000",
