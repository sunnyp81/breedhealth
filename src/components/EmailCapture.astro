---
interface Props {
  ctaText?: string;
}

const { ctaText = 'Get breed health tips delivered to your inbox' } = Astro.props;
---

<section class="bg-bg-alt border border-border rounded-2xl p-6 sm:p-8 my-8">
  <div class="max-w-xl mx-auto text-center">
    <div class="text-3xl mb-3" aria-hidden="true">🐾</div>
    <h2 class="text-xl sm:text-2xl font-bold text-primary mb-2">{ctaText}</h2>
    <p class="text-text-muted text-sm mb-6">
      Expert advice on breed health, common conditions, and preventive care — straight to your inbox. No spam, unsubscribe anytime.
    </p>

    <form
      id="email-capture-form"
      class="flex flex-col sm:flex-row gap-3 justify-center"
      novalidate
    >
      <input type="hidden" name="accessKey" value="YOUR_ACCESS_KEY" />
      <input type="hidden" name="redirectTo" value="" id="redirect-to-field" />

      <label for="email-input" class="sr-only">Email address</label>
      <input
        id="email-input"
        type="email"
        name="email"
        required
        placeholder="your@email.com"
        class="flex-1 px-4 py-3 rounded-lg border border-border bg-white text-text placeholder-text-light focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent text-sm"
        autocomplete="email"
      />
      <button
        type="submit"
        class="px-6 py-3 bg-primary hover:bg-primary-dark text-white font-semibold rounded-lg transition-colors text-sm whitespace-nowrap cursor-pointer"
      >
        Subscribe Free
      </button>
    </form>

    <div
      id="email-success"
      class="hidden mt-4 p-4 bg-primary/10 border border-primary/30 rounded-lg text-primary font-medium text-sm"
      role="status"
      aria-live="polite"
    >
      You're in! Check your inbox for a confirmation email.
    </div>

    <div
      id="email-error"
      class="hidden mt-4 p-4 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm"
      role="alert"
      aria-live="assertive"
    >
      Something went wrong. Please try again.
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('email-capture-form') as HTMLFormElement | null;
  const successMsg = document.getElementById('email-success');
  const errorMsg = document.getElementById('email-error');
  const redirectField = document.getElementById('redirect-to-field') as HTMLInputElement | null;

  if (redirectField) {
    redirectField.value = window.location.href;
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form) return;

    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Subscribing...';
    }

    errorMsg?.classList.add('hidden');

    try {
      const data = new FormData(form);
      const response = await fetch('https://api.staticforms.xyz/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(Object.fromEntries(data.entries())),
      });

      if (response.ok) {
        form.classList.add('hidden');
        successMsg?.classList.remove('hidden');
      } else {
        throw new Error('Submission failed');
      }
    } catch {
      errorMsg?.classList.remove('hidden');
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Subscribe Free';
      }
    }
  });
</script>
