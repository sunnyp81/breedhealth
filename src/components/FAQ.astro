---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
}

const { items } = Astro.props;
---

<div class="space-y-3 my-6">
  {items.map((item) => (
    <details class="group border border-border rounded-xl overflow-hidden bg-white">
      <summary class="flex items-center justify-between gap-4 px-5 py-4 cursor-pointer list-none font-semibold text-text hover:bg-bg-alt transition-colors select-none">
        <span>{item.question}</span>
        <span
          class="flex-shrink-0 w-6 h-6 rounded-full border-2 border-primary text-primary flex items-center justify-center text-sm font-bold transition-transform group-open:rotate-45"
          aria-hidden="true"
        >
          +
        </span>
      </summary>
      <div class="px-5 pb-5 pt-2 text-text-muted leading-relaxed border-t border-border">
        <p>{item.answer}</p>
      </div>
    </details>
  ))}
</div>
